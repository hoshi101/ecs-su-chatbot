# HERO Bot - FSS Hero Chatbot Environment Configuration

# === REQUIRED: Core API Keys ===
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_URL=your_qdrant_url_here  # e.g., https://xyz.qdrant.io:6333
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# === HERO Bot Domain Configuration ===
DOMAIN_NAME=Finansia Hero Trading Platform
BOT_NAME=HERO Bot
SEARCH_DOMAINS=www.finansiahero.com,smartaccess.fnsyrus.com/open-board/

# === HERO Bot Intelligence Settings ===
# Enable/disable query enhancement (default: true)
ENABLE_QUERY_ENHANCEMENT=true
# Similarity threshold for document relevance (default: 0.7)
DEFAULT_SIMILARITY_THRESHOLD=0.7
# Temperature for financial accuracy (default: 0.3)
FINANCIAL_TEMPERATURE=0.3

# === Vector Database Configuration ===
QDRANT_COLLECTION_NAME=fsshero-chatbot-bge-m3
EMBED_MODEL=BAAI/bge-m3
# BGE-M3 embedding dimensions (do not change)
EMBED_DIMENSIONS=1024

# === Document Processing ===
DOC_SOURCE_DIR=data

# === Rate Limiting Configuration ===
# Enable/disable rate limiting (default: true)
RATE_LIMIT_ENABLED=true
# Maximum requests per minute per IP (default: 10)
RATE_LIMIT_PER_MINUTE=10
# Rate limit strategy: fixed-window or moving-window (default: fixed-window)
RATE_LIMIT_STRATEGY=fixed-window
