meta {
  name: 01 Health
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/health
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("health status is ok", function() {
    const body = JSON.parse(res.getBody());
    expect(body.status).to.equal("ok");
  });
}
