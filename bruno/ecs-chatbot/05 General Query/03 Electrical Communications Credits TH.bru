meta {
  name: 03 Electrical Communications Credits TH
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-general-ec-credits-th",
    "query": "หลักสูตรวิศวกรรมไฟฟ้าสื่อสาร พ.ศ. 2565 รวมกี่หน่วยกิต",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("uses domain flow with evidence", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    expect(body.trace_events[0].details.precheck_intent).to.equal("domain_question");
    if (!Array.isArray(body.sources) || body.sources.length === 0) {
      throw new Error("expected at least one source for curriculum answer");
    }
  });
  test("mentions expected credit count", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    if (!String(body.response).includes("146")) {
      throw new Error("expected electrical communications 2565 answer to mention 146 credits");
    }
  });
}
