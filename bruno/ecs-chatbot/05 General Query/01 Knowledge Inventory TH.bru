meta {
  name: 01 Knowledge Inventory TH
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-general-knowledge-inventory-th",
    "query": "น้องไฟฟ้ามีข้อมูลอะไรบ้างในระบบ",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("answers with capability shortcut", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    expect(body.trace_events[0].details.precheck_intent).to.equal("capability");
    expect(body.sources.length).to.equal(0);
    if (typeof body.response !== "string" || !body.response.trim()) {
      throw new Error("missing response text");
    }
  });
}
