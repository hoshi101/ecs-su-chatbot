meta {
  name: 04 Department Overview TH
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-general-department-overview-th",
    "query": "ภาควิชาวิศวกรรมไฟฟ้าศิลปากรมีหลักสูตรอะไรบ้าง",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("uses domain flow and returns a concise answer", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    expect(body.trace_events[0].details.precheck_intent).to.equal("domain_question");
    if (typeof body.response !== "string" || body.response.trim().length < 20) {
      throw new Error("expected meaningful response text");
    }
    if (!Array.isArray(body.sources) || body.sources.length === 0) {
      throw new Error("expected at least one source for department overview");
    }
  });
}
