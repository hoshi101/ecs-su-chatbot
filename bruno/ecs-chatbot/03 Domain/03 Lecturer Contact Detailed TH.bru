meta {
  name: 03 Lecturer Contact Detailed TH
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-domain-lecturer-contact-th",
    "query": "ขอข้อมูลติดต่ออาจารย์ประจำสาขาพร้อมอีเมล",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("stays in domain flow", function() {
    const body = JSON.parse(res.getBody());
    expect(body.trace_events[0].details.precheck_intent).to.equal("domain_question");
    if (body.trace_events[0].description.startsWith("Shortcut response selected")) {
      throw new Error("expected non-shortcut route");
    }
  });
}
