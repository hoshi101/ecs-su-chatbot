meta {
  name: 11 Mixed Contact + Detail TH
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-mixed-contact-detail-th",
    "query": "ขอเบอร์โทรภาควิชาและข้อมูลอาจารย์ผู้ประสานงาน",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("routes to normal domain flow", function() {
    const body = JSON.parse(res.getBody());
    expect(body.trace_events[0].details.precheck_intent).to.equal("domain_question");
    if (body.trace_events[0].description.startsWith("Shortcut response selected")) {
      throw new Error("expected non-shortcut route");
    }
  });
}
