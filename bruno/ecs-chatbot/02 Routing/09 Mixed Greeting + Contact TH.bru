meta {
  name: 09 Mixed Greeting + Contact TH
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-mixed-greeting-contact-th",
    "query": "สวัสดี ขอข้อมูลติดต่อภาควิชาหน่อย",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("routes to normal domain flow", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    expect(body.trace_events[0].details.precheck_intent).to.equal("domain_question");
    if (body.trace_events[0].description.startsWith("Shortcut response selected")) {
      throw new Error("expected non-shortcut route");
    }
  });
}
