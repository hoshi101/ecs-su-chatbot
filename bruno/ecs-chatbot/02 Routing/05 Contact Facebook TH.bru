meta {
  name: 05 Contact Facebook TH
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-contact-facebook-th",
    "query": "facebook ภาควิชา",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("routes to contact shortcut", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    expect(body.trace_events[0].details.precheck_intent).to.equal("contact");
    expect(body.trace_events[0].details.shortcut_variant).to.equal("contact_template");
    expect(body.sources.length).to.equal(0);
  });
}
