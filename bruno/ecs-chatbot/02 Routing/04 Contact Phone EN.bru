meta {
  name: 04 Contact Phone EN
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-contact-phone-en",
    "query": "What is the department phone number?",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("routes to contact shortcut", function() {
    const body = JSON.parse(res.getBody());
    expect(body.trace_events[0].details.precheck_intent).to.equal("contact");
    expect(body.trace_events[0].details.shortcut_variant).to.equal("contact_template");
    expect(body.sources.length).to.equal(0);
  });
}
