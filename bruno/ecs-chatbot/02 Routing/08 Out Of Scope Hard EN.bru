meta {
  name: 08 Out Of Scope Hard EN
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/chat/
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}-oob-hard-en",
    "query": "Who is the prime minister of Thailand?",
    "enable_web_search": true,
    "force_web_search": false,
    "similarity_threshold": {{similarityThreshold}},
    "llm_provider": "{{provider}}",
    "llm_model": "{{model}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("routes to hard out-of-scope shortcut", function() {
    const rawBody = res.getBody();
    const body = typeof rawBody === "string" ? JSON.parse(rawBody) : rawBody;
    expect(body.trace_events[0].details.precheck_intent).to.equal("out_of_scope");
    expect(body.trace_events[0].details.shortcut_variant).to.equal("hard_oob");
    expect(body.sources.length).to.equal(0);
  });
}
