                  "pm.test('retrieval response contract is valid', function () {",
                  "  pm.expect(body.original_query).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.results).to.be.an('array');",
                  "  pm.expect(body.total_results).to.eql(body.results.length);",
                  "  pm.expect(body.retrieval_latency_ms).to.be.a('number');",
                  "  pm.expect(body.collection_stats).to.be.an('object');",
